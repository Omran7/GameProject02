<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameProject02.Views.ManagerReportPage"
             Title="📋 تقديم بلاغ"
             BackgroundColor="#1a1a1a"
             FlowDirection="RightToLeft">

	<ScrollView>
		<VerticalStackLayout Padding="20" Spacing="15">
			<Label Text="تقديم طلب حظر لاعب" TextColor="#f39c12" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>

			<Label Text="اسم اللاعب المستهدف:" TextColor="White" FontAttributes="Bold"/>
			<Entry x:Name="TargetUsernameEntry" Placeholder="أدخل اسم اللاعب..." TextColor="White" PlaceholderColor="#888888"/>

			<Label Text="سبب التبليغ:" TextColor="White" FontAttributes="Bold"/>
			<Editor x:Name="ReasonEditor" Placeholder="اشرح سبب طلب الحظر..." TextColor="White" PlaceholderColor="#888888" HeightRequest="120"/>

			<Label Text="إرفاق صورة (اختياري):" TextColor="White" FontAttributes="Bold"/>
			<Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
				<Label x:Name="ImagePathLabel" Text="لم يتم اختيار صورة" TextColor="#bdc3c7" VerticalOptions="Center"/>
				<Button Grid.Column="1" Text="📷 اختيار" BackgroundColor="#3498db" TextColor="White" CornerRadius="8" WidthRequest="80" Clicked="OnPickImageClicked"/>
			</Grid>

			<Button Text="📤 إرسال البلاغ" BackgroundColor="#e67e22" TextColor="White" CornerRadius="10" HeightRequest="48"
                    Clicked="OnSubmitClicked"/>

			<ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" Color="#f39c12" HorizontalOptions="Center"/>
		</VerticalStackLayout>
	</ScrollView>
</ContentPage>