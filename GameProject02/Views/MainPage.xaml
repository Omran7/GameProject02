<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:GameProject02.Views"
             x:Class="GameProject02.MainPage"
             BackgroundColor="Black"
             FlowDirection="RightToLeft"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *">
        <!-- Sticky Top Bar -->
        <views:TopHeaderView Grid.Row="0" x:Name="StickyHeader" />

        <!-- Scrollable Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="Start">

                <Label Text="CRIME CITY HUD" FontSize="20" TextColor="#45b7d1" HorizontalOptions="Center" FontAttributes="Bold" Margin="0,10" />

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto" ColumnSpacing="15" RowSpacing="15">

                    <Button Grid.Row="0" Grid.Column="0" x:Name="GymButton" Text="💪 النادي" 
                            BackgroundColor="#ff6b6b" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnGymClicked"/>

                    <Button Grid.Row="0" Grid.Column="1" x:Name="SchoolButton" Text="🎓 المدرسة" 
                            BackgroundColor="#45b7d1" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnSchoolClicked"/>

                    <Button Grid.Row="1" Grid.Column="0" x:Name="StockButton" Text="📦 المخزن" 
                            BackgroundColor="#9b59b6" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnStockClicked"/>

                    <Button Grid.Row="1" Grid.Column="1" Text="🏪 سوق المدينة" 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnMarketClicked"/>

                    <Button Grid.Row="2" Grid.Column="0" Text="🏴‍☠️ متجر العصابات"
                            BackgroundColor="#9b59b6" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnGangMarketClicked"/>

                    <Button Grid.Row="2" Grid.Column="1" Text="🕵️ السوق السوداء"
                            BackgroundColor="#2c3e50" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnBlackMarketClicked"/>

                    <Button Grid.Row="3" Grid.Column="0" Text="🏘️ العقارات" 
                            BackgroundColor="#f39c12" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnEstateClicked"/>

                    <Button Grid.Row="3" Grid.Column="1" Text="💼 مكتب العمل"
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnWorkOfficeClicked"/>

                    <Button Grid.Row="4" Grid.Column="0" Text="⚔️ نادي القتال"
                            BackgroundColor="#e74c3c" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnFightClubClicked"/>

                    <Button Grid.Row="4" Grid.Column="1" Text="🏥 المستشفى" 
                            BackgroundColor="#e74c3c" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnHospitalClicked"/>

                    <Button Grid.Row="5" Grid.Column="0" Text="🔒 السجن" 
                            BackgroundColor="#e74c3c" TextColor="White" HeightRequest="60" CornerRadius="12" Clicked="OnPrisonClicked"/>

                    <Button Grid.Row="5" Grid.Column="1" Text="🏙️ الخريطة" 
                            BackgroundColor="#2ecc71" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnCityMapClicked"/>
                    
                    <Button Grid.Row="6" Grid.Column="1" Text="🏙️ مدينة إدلب" 
                            BackgroundColor="#2ecc71" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnIdlibCityMapClicked"/>

                    <Button Grid.Row="6" Grid.Column="0" Text="🔔 الإشعارات" 
                            BackgroundColor="#e74c3c" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnNotificationCenterClicked"/>
                  
                    <Button Grid.Row="7" Grid.Column="1" Text="🔔 الأخبار" 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnNewsClicked"/>

                    <Button Grid.Row="7" Grid.Column="0" Text="✈️ المطار" 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnAirportClicked"/>

                    <Button Grid.Row="8" Grid.Column="1" Text="💬 الشات" 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnChatClicked"/>
                    
                    <Button Grid.Row="8" Grid.Column="0" Text="💬 الرسائل الخاصة" 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnPrivateChatClicked"/>

                    <Button Grid.Row="9" Grid.Column="1" Text="المهارات " 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnSkillsClicked"/>
                    
                    <Button Grid.Row="9" Grid.Column="0" Text="عجلة الحظ " 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnLuckyWheelClicked"/>
                    
                    <Button Grid.Row="10" Grid.Column="1" Text="متجر الذهب " 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnTheShopClicked"/>

                    <Button Grid.Row="10" Grid.Column="0" Text="🏅 الميداليات " 
                            BackgroundColor="#8e44ad" TextColor="White" HeightRequest="60" CornerRadius="12" FontAttributes="Bold" Clicked="OnMedalsClicked"/>
                </Grid>

                <Button Text="👤 الملف الشخصي" 
                        BackgroundColor="#45b7d1" TextColor="White" HeightRequest="50" CornerRadius="25" Clicked="OnProfileClicked" Margin="0,20,0,0"/>

                <Button Text="🏪 مقر العصابة"
                        BackgroundColor="#9b59b6" TextColor="White" HeightRequest="50" CornerRadius="25" Clicked="OnGangClicked"/>
                <Button Text="🏪 الجريمة"
                        BackgroundColor="#9b59b6" TextColor="White" HeightRequest="50" CornerRadius="25" Clicked="OnCrimeClicked"/>

                <!-- Language switcher button -->
                <Button Text="🌐 تغيير اللغة" 
                        BackgroundColor="#2c3e50" TextColor="White" HeightRequest="50" CornerRadius="12" Clicked="OnSwitchLanguageClicked"/>

                <Button Text="🚪 تسجيل الخروج" 
                        BackgroundColor="#c0392b" TextColor="White" HeightRequest="50" CornerRadius="12" Clicked="OnSignOutClicked"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
