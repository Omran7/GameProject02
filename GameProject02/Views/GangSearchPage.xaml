<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameProject02.Views.GangSearchPage"
             ControlTemplate="{StaticResource StickyHeaderTemplate}"
             BackgroundColor="#1a1a1a"
             Title="🔍 البحث عن عصابة"
             FlowDirection="RightToLeft"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="#0a0a0a" Stroke="#e74c3c" StrokeThickness="2" Padding="10">
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="🔍 البحث عن عصابة" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Button Grid.Column="1" Text="← رجوع" BackgroundColor="#95a5a6" TextColor="White" CornerRadius="8" WidthRequest="80" Clicked="OnBackClicked"/>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" RowDefinitions="Auto,Auto,*" Padding="15">
            <!-- Search Box -->
            <Border BackgroundColor="#2c2c2c" Stroke="#3498db" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="15">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" RowDefinitions="auto,auto">
                    <Entry Grid.Row="0" x:Name="SearchEntry" Placeholder="اسم أو رمز العصابة" TextColor="White" PlaceholderColor="#888" BackgroundColor="#333" Keyboard="Text"/>
                    <Button Grid.Row="1" Text="🔍 بحث" BackgroundColor="#3498db" TextColor="White" CornerRadius="8" WidthRequest="80" Clicked="OnSearchClicked"/>
                </Grid>
            </Border>

            <!-- ✅ FIXED: StatusLabel with exact x:Name matching C# -->
            <Label x:Name="StatusLabel" 
                   Grid.Row="1" 
                   Text="📝 ابحث عن عصابة بالاسم أو المعرف" 
                   TextColor="#bdc3c7" 
                   FontSize="13" 
                   HorizontalOptions="Center" 
                   Margin="0,10,0,10"/>

            <!-- Results List -->
            <CollectionView x:Name="ResultsList" 
                            Grid.Row="2" 
                            SelectionMode="Single" 
                            SelectionChanged="OnGangSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="#2c2c2c" Stroke="#444" StrokeThickness="1" Margin="0,0,0,8" Padding="12" StrokeShape="RoundRectangle 10">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                                    <Label Text="{Binding Tag, StringFormat='[ {0} ]'}" TextColor="#f39c12" FontSize="12"/>
                                    <Label Text="{Binding MembersWithPositions.Count, StringFormat='الأعضاء: {0}/50'}" TextColor="#bdc3c7" FontSize="12"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="طلب انضمام" TextColor="#2ecc71" FontSize="12" VerticalOptions="Center" HorizontalOptions="End"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>

        <!-- Bottom Bar -->
        <Border Grid.Row="2" BackgroundColor="#0a0a0a" Stroke="#e74c3c" StrokeThickness="2" StrokeShape="RoundRectangle 15,15,0,0" Margin="10,5,10,10" Padding="10">
            <Button Text="🏠 الرئيسية" BackgroundColor="#3498db" TextColor="White" CornerRadius="12" FontAttributes="Bold" Clicked="OnHomeClicked"/>
        </Border>
    </Grid>
</ContentPage>