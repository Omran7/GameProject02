<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameProject02.Views.GangMarketPage"
             ControlTemplate="{StaticResource StickyHeaderTemplate}"
             BackgroundColor="#1a1a1a"
             NavigationPage.HasNavigationBar="False"
             FlowDirection="RightToLeft">

	<Grid RowDefinitions="Auto,*,Auto">

		<!-- Background -->
		<Image Grid.RowSpan="3"
               Source="market_bg.jpg"
               Aspect="AspectFill"
               Opacity="1"/>

		<!-- Header -->
		<Border Grid.Row="0"
                BackgroundColor="Transparent"
                Stroke="#1a1a1a"
                StrokeShape="RoundRectangle 0,0,20,20"
                Padding="0">

			<Grid HeightRequest="30">
				<Image Source="market_header_bg.jpg"
                       Aspect="Fill"
                       Opacity="1"/>
				<Label x:Name="CategoryTitleLabel"
                       TextColor="#C3C9BD"
                       FontFamily="MCS-ALMAALIM"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="16"/>
			</Grid>
		</Border>

		<!-- Items List -->
		<ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
			<VerticalStackLayout x:Name="ItemsContainer" Spacing="12" Padding="10">
				<Grid x:Name="ItemsGrid" ColumnSpacing="10" RowSpacing="10">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
				</Grid>

				<StackLayout x:Name="EmptyState" IsVisible="False"
                             VerticalOptions="Center" HorizontalOptions="Center"
                             Margin="0,50,0,0" Spacing="15">
					<Label Text="🏪" FontSize="60" HorizontalOptions="Center"/>
					<Label Text="لا توجد عناصر في هذا القسم"
                           TextColor="#bdc3c7" HorizontalOptions="Center" FontSize="14"/>
				</StackLayout>
			</VerticalStackLayout>
		</ScrollView>

		<!-- Bottom Bar -->
		<Border Grid.Row="2"
                BackgroundColor="#2c3e50"
                Stroke="Transparent"
                Padding="10">

			<Grid ColumnDefinitions="*,*" ColumnSpacing="10">
				<Button Text="← رجوع"
                        BackgroundColor="#e74c3c"
                        TextColor="White"
                        CornerRadius="8"
                        Clicked="OnBackClicked"/>

				<Button Text="🔄 تحديث"
                        BackgroundColor="#3498db"
                        TextColor="White"
                        CornerRadius="8"
                        Clicked="OnRefreshClicked"/>
			</Grid>
		</Border>
	</Grid>
</ContentPage>