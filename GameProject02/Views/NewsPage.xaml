<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:GameProject02.Models"
             xmlns:converters="clr-namespace:GameProject02.Converters"
             x:Class="GameProject02.Views.NewsPage"
             Title="Intelligence Terminal"
             BackgroundColor="#050505">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:StringNotNullOrEmptyConverter x:Key="StringNotNullOrEmptyConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- HEADER: SERVER INTEL (Old Project Style) -->
        <Grid Grid.Row="0" ColumnDefinitions="*, *, *" Padding="15,10" BackgroundColor="#111">
            <VerticalStackLayout Grid.Column="0">
                <Label Text="SERVER #1" TextColor="#45b7d1" FontSize="10" FontAttributes="Bold" />
                <Label x:Name="ServerDayLabel" Text="FRIDAY" TextColor="#666" FontSize="10" />
            </VerticalStackLayout>

            <Label Grid.Column="1" Text="LATEST INTEL" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" CharacterSpacing="2"/>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="End">
                <Label x:Name="ServerTimeLabel" Text="00:00:00" TextColor="#45b7d1" FontSize="12" FontAttributes="Bold" HorizontalOptions="End"/>
                <Label x:Name="ServerDateLabel" Text="01-05-2026" TextColor="#666" FontSize="10" HorizontalOptions="End" />
            </VerticalStackLayout>
            <BoxView Grid.Row="0" Grid.ColumnSpan="3" HeightRequest="1" BackgroundColor="#45b7d1" VerticalOptions="End" Opacity="0.3"/>
        </Grid>

        <!-- NEWS FEED -->
        <CollectionView Grid.Row="1" x:Name="NewsList" SelectionMode="None">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:NewsItem">
                    <Grid Padding="15,5">
                        <Border BackgroundColor="#111" Stroke="#222" StrokeThickness="1" Padding="15">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>

                            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="15">
                                <!-- Icon / Graphic -->
                                <Label Grid.RowSpan="3" Text="{Binding Icon}" FontSize="28" VerticalOptions="Start" HorizontalOptions="Center" WidthRequest="40"/>

                                <!-- Meta Information -->
                                <HorizontalStackLayout Grid.Row="0" Grid.Column="1" Spacing="10">
                                    <Label Text="{Binding Date, StringFormat='{0:HH:mm}'}" TextColor="#45b7d1" FontSize="10" FontAttributes="Bold" />
                                    <Label Text="|" TextColor="#333" />
                                    <Label Text="{Binding Type}" TextColor="#666" FontSize="10" TextTransform="Uppercase" />
                                </HorizontalStackLayout>

                                <!-- Title or Author -->
                                <HorizontalStackLayout Grid.Row="1" Grid.Column="1" Spacing="5">
                                    <Label Text="{Binding Title}" TextColor="White" FontSize="14" FontAttributes="Bold" IsVisible="{Binding Title, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                                    <Label Text="{Binding Author}" TextColor="#3498db" FontSize="14" FontAttributes="Bold" IsVisible="{Binding Author, Converter={StaticResource StringNotNullOrEmptyConverter}}" />
                                </HorizontalStackLayout>

                                <!-- Content & Reward -->
                                <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="5" Margin="0,5,0,0">
                                    <Label Text="{Binding Content}" TextColor="#999" FontSize="12" LineBreakMode="WordWrap" />
                                    <HorizontalStackLayout IsVisible="{Binding Reward, Converter={StaticResource StringNotNullOrEmptyConverter}}" Spacing="10">
                                        <Label Text="REWARD:" TextColor="#ff6b6b" FontSize="12" FontAttributes="Bold"/>
                                        <Label Text="{Binding Reward}" TextColor="Gold" FontSize="12" FontAttributes="Bold"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- BOTTOM BAR: PUBLISH SYSTEM -->
        <Grid Grid.Row="2" Padding="15" ColumnDefinitions="*, Auto" BackgroundColor="#0a0a0a">
            <Label Text="Broadcast a message for 💰 20,000" VerticalOptions="Center" TextColor="#444" FontSize="12" />
            <Button Grid.Column="1" 
                    Text="PUBLISH AD" 
                    Clicked="OnPublishAdClicked"
                    BackgroundColor="#45b7d1" 
                    TextColor="Black" 
                    FontAttributes="Bold"
                    Padding="20,0"
                    HeightRequest="40"
                    CornerRadius="4" />
        </Grid>
    </Grid>
</ContentPage>
