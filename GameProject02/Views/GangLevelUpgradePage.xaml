<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameProject02.Views.GangLevelUpgradePage"
             ControlTemplate="{StaticResource StickyHeaderTemplate}"
             BackgroundColor="#1a1a1a"
             Title="⭐ ترقية العصابة"
             FlowDirection="RightToLeft"
             NavigationPage.HasNavigationBar="False">
    <Grid RowDefinitions="Auto,*,Auto">
        <Border BackgroundColor="#0a0a0a" Stroke="#e74c3c" StrokeThickness="2" Padding="10">
            <Label Text="⭐ ترقية مستوى العصابة" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
        </Border>
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="15">
                <Label x:Name="CurrentLevelLabel" Text="المستوى الحالي: 1" TextColor="White" FontSize="16"/>
                <Label x:Name="NextLevelLabel" Text="المستوى التالي: 2" TextColor="#f39c12" FontSize="16" FontAttributes="Bold"/>
                <Border BackgroundColor="#2c2c2c" Stroke="#3498db" StrokeThickness="1" Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label x:Name="MembersReqLabel" Text="الأعضاء المطلوبين: 5" TextColor="#bdc3c7"/>
                        <Label x:Name="RespectReqLabel" Text="الاحترام المطلوب: 1000" TextColor="#bdc3c7"/>
                        <Label x:Name="CashReqLabel" Text="النقد المطلوب: 5000" TextColor="#bdc3c7"/>
                    </VerticalStackLayout>
                </Border>
                <Label x:Name="StatusLabel" TextColor="#e74c3c" FontSize="14"/>
            </VerticalStackLayout>
        </ScrollView>
        <Border Grid.Row="2" BackgroundColor="#0a0a0a" Stroke="#e74c3c" StrokeThickness="2" Margin="10" Padding="10">
            <Button x:Name="UpgradeButton" Text="⭐ ترقية العصابة" BackgroundColor="#e67e22" TextColor="White" CornerRadius="12" Clicked="OnUpgradeClicked"/>
        </Border>
    </Grid>
</ContentPage>