<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GameProject02.Views"
             xmlns:controls="clr-namespace:GameProject02.Controls"
             x:Class="GameProject02.Views.EstateOwnPage"
             NavigationPage.HasNavigationBar="False"
             Title="عقاراتك الخاصة"
             FlowDirection="RightToLeft">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">
        <Image Source="background.png" Aspect="AspectFill" Opacity="1" Grid.RowSpan="3"/>
        <local:GameHeader HeaderTitle="عقاراتك الخاصة" Grid.Row="0"/>
        <ScrollView Grid.Row="1" Margin="5,0,5,0">
            <VerticalStackLayout x:Name="EstatesContainer" Spacing="0" HorizontalOptions="Fill"/>
        </ScrollView>

        <!-- الفوتر العام من مجلد Controls -->
        <controls:FooterView x:Name="PageFooter" Grid.Row="2" />
    </Grid>
</ContentPage>