<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             ControlTemplate="{StaticResource StickyHeaderTemplate}"
             x:Class="GameProject02.Views.AdminAnnouncementPage"
             Title="📢 إعلان نظام"
             BackgroundColor="#1a1a1a"
             FlowDirection="RightToLeft">

    <VerticalStackLayout Padding="20" Spacing="20">
        <Label Text="نص الإعلان:" TextColor="White"/>
        <Editor x:Name="MessageEntry" BackgroundColor="#252525" TextColor="White" HeightRequest="150" Placeholder="اكتب نص الإعلان هنا..."/>

        <Button Text="📤 نشر الإعلان" BackgroundColor="#3498db" TextColor="White" CornerRadius="10" HeightRequest="48"
                Clicked="OnSendClicked"/>
    </VerticalStackLayout>
</ContentPage>