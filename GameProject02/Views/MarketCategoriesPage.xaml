<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GameProject02.Views"
             xmlns:controls="clr-namespace:GameProject02.Controls"
             x:Class="GameProject02.Views.MarketCategoriesPage"
             ControlTemplate="{StaticResource StickyHeaderTemplate}"
             Title="السوق"
             FlowDirection="RightToLeft"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">
        <!-- خلفية موحدة -->
        <Image Source="background.png" Aspect="AspectFill" Opacity="1" Grid.RowSpan="3"/>

        <!-- هيدر موحد -->
        <local:GameHeader HeaderTitle="سوق المدينة الكبير" Grid.Row="0"/>

        <!-- قائمة البطاقات -->
        <ScrollView Grid.Row="1" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout x:Name="CategoriesContainer" 
                                 Spacing="0"
                                 Padding="0"/>
        </ScrollView>

        <!-- فوتر موحد -->
        <controls:FooterView x:Name="PageFooter" Grid.Row="2" />
    </Grid>
</ContentPage>