<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GameProject02.Views.BlackMarketConversionPage"
             ControlTemplate="{StaticResource StickyHeaderFooterTemplate}"
             BackgroundColor="#1a1a1a"
             FlowDirection="RightToLeft"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" BackgroundColor="#0a0a0a" Stroke="#e74c3c" StrokeThickness="2" Padding="10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Button Text="← رجوع" BackgroundColor="#95a5a6" TextColor="White" CornerRadius="8" WidthRequest="80" Clicked="OnBackClicked"/>
                <Label x:Name="CategoryTitle" Grid.Column="1" Text="التحويل" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
            </Grid>
        </Border>

        <CollectionView x:Name="RecipesList" Grid.Row="1" Margin="10" SelectionMode="Single" SelectionChanged="OnRecipeSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#2c2c2c" Stroke="#444" StrokeThickness="1" Margin="0,0,0,8" Padding="12" StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="Auto,*,Auto" RowSpacing="5" ColumnSpacing="10">
                            <Image Grid.RowSpan="2" Source="{Binding ImageResource}" HeightRequest="50" WidthRequest="50" Aspect="AspectFit"/>
                            <Label Grid.Column="1" Text="{Binding Name}" TextColor="White" FontSize="15" FontAttributes="Bold"/>
                            <Label Grid.Column="1" Grid.Row="1" Text="{Binding Description}" TextColor="#bdc3c7" FontSize="12"/>
                            <Label Grid.Column="2" Text="{Binding RequiredAmount, StringFormat='المطلوب: {0}'}" TextColor="#e74c3c" FontSize="12" HorizontalOptions="End"/>
                            <Label Grid.Column="2" Grid.Row="1" Text="{Binding RewardAmount, StringFormat='المكافأة: {0}'}" Padding="0,30,0,0" TextColor="#2ecc71" FontSize="12" HorizontalOptions="End"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border x:Name="ConvertPanel" Grid.Row="1" BackgroundColor="#252525" Stroke="#e74c3c" StrokeThickness="2" Padding="15" IsVisible="False" VerticalOptions="End" StrokeShape="RoundRectangle 20,20,0,0">
            <VerticalStackLayout Spacing="12">
                <Label x:Name="SelectedRecipeName" TextColor="White" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="الكمية:" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                <Slider x:Name="QuantitySlider" Minimum="1" Maximum="10" Value="1" ValueChanged="OnQuantityChanged"/>
                <Entry x:Name="QuantityEntry" Text="1" Keyboard="Numeric" TextChanged="OnQuantityTextChanged" MaxLength="2" HorizontalOptions="Center" WidthRequest="60" TextColor="White" BackgroundColor="#333"/>
                <Label x:Name="StatusLabel" TextColor="#bdc3c7" FontSize="12" HorizontalOptions="Center"/>
                <Button x:Name="ConvertButton" Text="تحويل" BackgroundColor="#e74c3c" TextColor="White" CornerRadius="10" HeightRequest="45" IsEnabled="False" Clicked="OnConvertClicked"/>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="2" BackgroundColor="#0a0a0a" Stroke="#e74c3c" StrokeThickness="2" StrokeShape="RoundRectangle 15,15,0,0" Margin="10,5,10,10" Padding="10">
            <Button Text="🏠 الرئيسية" BackgroundColor="#3498db" TextColor="White" CornerRadius="12" FontAttributes="Bold" Clicked="OnHomeClicked"/>
        </Border>
    </Grid>
</ContentPage>