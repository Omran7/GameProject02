<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             ControlTemplate="{StaticResource StickyHeaderTemplate}"
             x:Class="GameProject02.Views.PlayerSelectionPage"
             Title="اختر لاعب"
             BackgroundColor="#1a1a1a">
    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0" BackgroundColor="#0a0a0a" Padding="10">
            <Label Text="اختر لاعب لبدء محادثة خاصة" TextColor="White" FontSize="16" HorizontalOptions="Center"/>
        </Border>

        <SearchBar x:Name="SearchBar" Grid.Row="1" Placeholder="ابحث عن لاعب..." 
                   BackgroundColor="#2d2d2d" TextColor="White" PlaceholderColor="#888"
                   TextChanged="OnSearchTextChanged"/>

        <CollectionView x:Name="PlayersList" Grid.Row="2" Margin="10"
                        SelectionMode="Single" SelectionChanged="OnPlayerSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border BackgroundColor="#2c2c2c" Stroke="#444" StrokeThickness="1" Margin="0,0,0,8" Padding="12" StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border Stroke="#3498db" StrokeThickness="1" StrokeShape="RoundRectangle 20" WidthRequest="45" HeightRequest="45">
                                <Label Text="👤" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1">
                                <Label Text="{Binding Username}" TextColor="White" FontSize="16" FontAttributes="Bold"/>
                                <Label Text="{Binding Level, StringFormat='مستوى {0}'}" TextColor="#bdc3c7" FontSize="12"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="💬" TextColor="#2ecc71" FontSize="20" VerticalOptions="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator x:Name="LoadingIndicator" IsRunning="True" IsVisible="True" Color="#3498db" HorizontalOptions="Center" VerticalOptions="Center"/>
    </Grid>
</ContentPage>