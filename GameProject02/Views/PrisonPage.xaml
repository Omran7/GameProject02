<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:GameProject02.Controls"
             xmlns:views="clr-namespace:GameProject02.Views"
             x:Class="GameProject02.Views.PrisonPage"
             BackgroundColor="#1a1a1a"
             FlowDirection="RightToLeft"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, Auto, *, Auto">

        <views:TopHeaderView Grid.Row="0"/>

        <!-- صورة خلفية الزائر -->
        <Image Source="background.png"
               Aspect="Fill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               Grid.Row="1"
               Grid.RowSpan="2"
               IsVisible="{Binding IsFreeMode}"/>

        <!-- صورة خلفية السجين -->
        <Image Source="prison_inmate_bg.png"
               Aspect="Fill"
               HorizontalOptions="Fill"
               VerticalOptions="Fill"
               Grid.Row="1"
               Grid.RowSpan="2"
               IsVisible="{Binding IsInPrison}"/>

        <!-- GameHeader يظهر للزائر فقط -->
        <views:GameHeader Grid.Row="1"
                          x:Name="PageHeader"
                          HeaderTitle="السجن"/>

        <Grid Grid.Row="2">

            <!-- الوضع 1: السجين -->
            <Grid x:Name="InmateModeLayout" IsVisible="{Binding IsInPrison}">
                <ScrollView>
                    <VerticalStackLayout Spacing="0" Padding="0">

                        <Border x:Name="InmateInfoCard"
                                Stroke="Transparent"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 10,10,10,10"
                                BackgroundColor="Transparent"
                                Padding="5"
                                HorizontalOptions="Center">
                            <VerticalStackLayout Spacing="0">
                                <Label Text="سبب السجن:"
                                       TextColor="Black"
                                       FontAttributes="Bold"/>
                                <Label x:Name="ReasonLabel"
                                       TextColor="Red"
                                       LineBreakMode="WordWrap"/>
                                <Label Text="الوقت المتبقي للخروج:"
                                       TextColor="Black"
                                       FontAttributes="Bold"/>
                                <Label x:Name="TimeRemainingLabel"
                                       Text="00:00:00"
                                       TextColor="Red"
                                       FontAttributes="Bold"/>
                                <Label Text="مبلغ الكفالة:"
                                       TextColor="Black"
                                       FontAttributes="Bold"/>
                                <Label x:Name="BailAmountLabel"
                                       Text="0 ذهب"
                                       TextColor="Red"/>
                                <Label x:Name="VisitCountLabel"
                                       Text="مرات السجن: 0"
                                       TextColor="Black"
                                       FontAttributes="Bold"/>
                            </VerticalStackLayout>
                        </Border>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>

            <!-- الوضع 2: الزائر -->
            <Grid x:Name="VisitorModeLayout" IsVisible="{Binding IsFreeMode}">
                <ScrollView VerticalOptions="Fill">
                    <VerticalStackLayout x:Name="PrisonersContainer"
                                         Spacing="0"
                                         Padding="10,5"
                                         VerticalOptions="Fill"/>
                </ScrollView>
            </Grid>
        </Grid>

        <controls:FooterView Grid.Row="3"
                             x:Name="PageFooter"/>
    </Grid>
</ContentPage>