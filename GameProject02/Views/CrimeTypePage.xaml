<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GameProject02.Views"
             xmlns:controls="clr-namespace:GameProject02.Controls"
             x:Class="GameProject02.Views.CrimeTypePage"
             ControlTemplate="{StaticResource StickyHeaderTemplate}"
             FlowDirection="RightToLeft"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,*,Auto" Padding="0">

        <Image Source="background.png" Aspect="AspectFill" Opacity="1" Grid.RowSpan="3"/>

        <!-- الهيدر -->
        <local:GameHeader x:Name="PageHeader"
                          Grid.Row="0"
                          HeaderTitle="جرائم النشال"
                          RightImage="header_right.png"
                          LeftImage="header_left.png"/>

        <!-- المحتوى -->
        <ScrollView Grid.Row="1" Margin="0,0,0,0">
            <VerticalStackLayout x:Name="CrimesContainer" Spacing="0"/>
        </ScrollView>

        <!-- الفوتر -->
        <controls:FooterView x:Name="PageFooter" Grid.Row="2"/>

    </Grid>
</ContentPage>