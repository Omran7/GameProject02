<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:GameProject02"
             xmlns:views="clr-namespace:GameProject02.Views"
             xmlns:converters="clr-namespace:GameProject02.Converters"
             x:Class="GameProject02.App">

    <Application.Resources>
        <ResourceDictionary>
            <!-- ✅ MERGED DICTIONARIES (styles only) -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles/EstateStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/PopupStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/StockStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Template for all Pages -->
            <ControlTemplate x:Key="StickyHeaderTemplate">
                <Grid RowDefinitions="Auto, *">
                    <!-- The Sticky Header stays at Row 0 -->
                    <views:TopHeaderView Grid.Row="0" />

                    <!-- The Page Content (MainPage, GamePage, etc.) loads in Row 1 -->
                    <ContentPresenter Grid.Row="1" />
                </Grid>
            </ControlTemplate>

            <!-- ✅ CONVERTERS (MUST BE OUTSIDE MergedDictionaries) -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:LockedToColorConverter x:Key="LockedToColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>