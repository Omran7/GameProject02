<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ========================================== -->
    <!-- أنماط النوافذ المنبثقة الموحدة -->
    <!-- ========================================== -->

    <!-- خلفية التعتيم -->
    <Style TargetType="BoxView" x:Key="PopupOverlay">
        <Setter Property="BackgroundColor" Value="#80000000"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- حاوية النافذة المنبثقة -->
    <Style TargetType="Border" x:Key="PopupContainer">
        <Setter Property="Stroke" Value="Transparent"/>
        <Setter Property="StrokeThickness" Value="0"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="IsVisible" Value="False"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="Scale" Value="0.8"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 10"/>
    </Style>

    <!-- عنوان النافذة -->
    <Style TargetType="Label" x:Key="PopupTitle">
        <Setter Property="FontFamily" Value="Cairo-Black"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="TextColor" Value="#000000"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="CharacterSpacing" Value="0"/>
        <Setter Property="Margin" Value="0,-5,0,0"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,1" Radius="5" Opacity="1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- نص الرسالة -->
    <Style TargetType="Label" x:Key="PopupMessage">
        <Setter Property="FontFamily" Value="Cairo-Black"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="TextColor" Value="Goldenrod"/>
        <Setter Property="HorizontalTextAlignment" Value="Center"/>
        <Setter Property="LineBreakMode" Value="WordWrap"/>
        <Setter Property="CharacterSpacing" Value="0.1"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,2" Radius="1" Opacity="1"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- نص الأزرار -->
    <Style TargetType="Label" x:Key="PopupButtonText">
        <Setter Property="FontFamily" Value="Cairo-Black"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="TextColor" Value="#000000"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,1" Radius="1" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- عنصر القائمة -->
    <Style TargetType="Label" x:Key="PopupListItem">
        <Setter Property="FontFamily" Value="Cairo-Black"/>
        <Setter Property="TextColor" Value="Goldenrod"/>
        <Setter Property="HorizontalOptions" Value="Start"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="CharacterSpacing" Value="0.1"/>
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="Black" Offset="0,2" Radius="1" Opacity="1"/>
            </Setter.Value>
        </Setter>

    </Style>

    <!-- زر الإجراء داخل النافذة (مثل شراء/استئجار) -->
    <Style TargetType="Border" x:Key="PopupActionButton">
        <Setter Property="Stroke" Value="Transparent"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 0"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HeightRequest" Value="40"/>
        <Setter Property="WidthRequest" Value="70"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
        <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>
    
    <!-- نمط نص أزرار الإجراءات (شراء / استئجار) -->
    <Style TargetType="Label" x:Key="PopupActionButtonText">
        <Setter Property="FontFamily" Value="Cairo-Black"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextColor" Value="#000000"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>
    
    <!-- زر الإلغاء داخل النافذة -->
    <Style TargetType="Border" x:Key="PopupCancelButton">
        <Setter Property="Stroke" Value="Transparent"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 0"/>
        <Setter Property="BackgroundColor" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="HeightRequest" Value="45"/>
        <Setter Property="WidthRequest" Value="120"/>
        <Setter Property="HorizontalOptions" Value="Center"/>
        <Setter Property="VerticalOptions" Value="Center"/>
    </Style>

</ResourceDictionary>